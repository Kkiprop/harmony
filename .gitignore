# Python/Django .gitignore

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
dist/
downloads/
eggs/
.eggs/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Django stuff
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Media files (user uploads)
/media/

# Static files collected
/staticfiles/

# Virtual environments
venv/
ENV/
env/
.env/
.venv/

# VS Code
.vscode/

# PyCharm
.idea/

# macOS
.DS_Store

# Windows
Thumbs.db

# Node
node_modules/

# Misc
*.swp
*.swo
*.tmp
*.bak

# Secrets
.env
.env.*

# Python tools
pip-wheel-metadata/

# Mypy
.mypy_cache/

# pyenv
.python-version

# Ignore media and static from uploads/builds
media/
staticfiles/

# Ignore compiled files
*.pyc

